@{
    ViewData["Title"] = "Đăng nhập";
}
<style>
    /* Reset body padding cho trang login */
    body {
        padding-top: 70px !important;
    }

    .footer {
        display: none !important;
    }


    main {
        position: fixed;
        top: 70px;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        padding: 0;
        margin: 0;
    }

    /* Video Background - Full Screen */
    .video-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        z-index: 0;
    }

    .video-background video {
        position: absolute;
        top: 50%;
        left: 50%;
        min-width: 100%;
        min-height: 100%;
        width: auto;
        height: auto;
        transform: translate(-50%, -50%);
        object-fit: cover;
        z-index: 0;
    }

    .video-background::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1;
    }

    /* Auth Container - Frosted Glass Effect like Header */
    .auth-container {
        /* background: rgba(0, 0, 0, 0.7) !important; */
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        padding: 2.5rem;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.1);
        width: 100%;
        max-width: 420px;
        position: relative;
        z-index: 2;
        border: 1px solid rgba(255, 255, 255, 0.12);
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .auth-container h2 {
        color: rgba(255, 255, 255, 0.95);
        font-weight: 700;
        margin-bottom: 1rem;
        text-align: center;
        font-size: 1.8rem;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    }

    /* Panda Container */
    .panda-container {
        width: 200px;
        height: 200px;
        margin: 0 auto 1.5rem;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        filter: drop-shadow(0 5px 15px rgba(0, 0, 0, 0.5));
    }

    .panda {
        width: 180px;
        height: 180px;
        position: relative;
    }

    /* Panda Head */
    .panda-face {
        width: 100%;
        height: 100%;
        background: #fff;
        border-radius: 50%;
        position: relative;
        border: 4px solid #2c3e50;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
    }

    /* Ears */
    .ear {
        width: 50px;
        height: 50px;
        background: #2c3e50;
        border-radius: 50%;
        position: absolute;
        top: 10px;
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.3);
    }

    .ear.left {
        left: 10px;
    }

    .ear.right {
        right: 10px;
    }

    /* Eyes */
    .eye-patch {
        width: 55px;
        height: 65px;
        background: #2c3e50;
        border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
        position: absolute;
        top: 45px;
    }

    .eye-patch.left {
        left: 25px;
        transform: rotate(-10deg);
    }

    .eye-patch.right {
        right: 25px;
        transform: rotate(10deg);
    }

    .eye {
        width: 20px;
        height: 20px;
        background: #fff;
        border-radius: 50%;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .pupil {
        width: 12px;
        height: 12px;
        background: #2c3e50;
        border-radius: 50%;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        transition: all 0.1s ease;
    }

    /* Eye closed state */
    .eye.closed {
        height: 3px;
        background: #2c3e50;
        border-radius: 0;
    }

    .eye.closed .pupil {
        display: none;
    }

    /* Panda hands */
    .panda-hand {
        width: 60px;
        height: 60px;
        background: #2c3e50;
        border-radius: 50%;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0;
        transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    }

    .panda-hand::after {
        content: '';
        width: 45px;
        height: 45px;
        background: #34495e;
        border-radius: 50%;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .panda-hand.left {
        left: -30px;
    }

    .panda-hand.right {
        right: -30px;
    }

    .panda-hand.cover-eyes {
        opacity: 1;
    }

    .panda-hand.left.cover-eyes {
        left: 20px;
    }

    .panda-hand.right.cover-eyes {
        right: 20px;
    }

    /* Nose */
    .nose {
        width: 18px;
        height: 15px;
        background: #2c3e50;
        border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
        position: absolute;
        top: 90px;
        left: 50%;
        transform: translateX(-50%);
    }

    /* Mouth */
    .mouth {
        width: 40px;
        height: 25px;
        border: 3px solid #2c3e50;
        border-top: none;
        border-radius: 0 0 50% 50%;
        position: absolute;
        top: 105px;
        left: 50%;
        transform: translateX(-50%);
    }

    .auth-container form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .auth-container input {
        padding: 0.75rem 1rem;
        border: 2px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        font-family: inherit;
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }

    .auth-container input::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .auth-container input:focus {
        outline: none;
        border-color: rgba(255, 255, 255, 0.3);
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
        background-color: rgba(255, 255, 255, 0.15);
    }

    .auth-container button {
        padding: 0.85rem 1rem;
        background: rgba(255, 255, 255, 0.2);
        color: #ffffff;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 0.5rem;
        backdrop-filter: blur(10px);
    }

    .auth-container button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.3);
        border-color: rgba(255, 255, 255, 0.5);
    }

    .auth-container button:active {
        transform: translateY(0);
    }

    .text-danger {
        color: #ff6b6b;
        font-size: 0.9rem;
        text-align: center;
        margin: 0;
        padding: 0.75rem;
        background-color: rgba(255, 107, 107, 0.2);
        border-radius: 8px;
        margin-bottom: 0.5rem;
        border: 1px solid rgba(255, 107, 107, 0.3);
        backdrop-filter: blur(10px);
    }

    .auth-container p {
        margin: 1rem 0 0 0;
        text-align: center;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.8);
    }

    .auth-container a {
        color: rgba(255, 255, 255, 0.95);
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .auth-container a:hover {
        color: #ffffff;
        text-decoration: underline;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
    }

    @@media (max-width: 768px) {
        body {
            padding-top: 60px !important;
        }

        main {
            top: 60px;
        }
    }

    @@media (max-width: 480px) {
        .auth-container {
            padding: 1.5rem;
            margin: 1rem;
            max-width: calc(100vw - 2rem);
        }

        .panda-container {
            width: 150px;
            height: 150px;
        }

        .panda {
            width: 140px;
            height: 140px;
        }

        .auth-container h2 {
            font-size: 1.5rem;
            margin-bottom: 0.8rem;
        }

        .auth-container input {
            padding: 0.65rem 0.8rem;
            font-size: 0.9rem;
        }

        .auth-container button {
            padding: 0.75rem;
            font-size: 0.95rem;
        }

        .auth-container p {
            font-size: 0.85rem;
        }
    }
</style>

<main>
    <!-- Video Background - Full Screen -->
    <div class="video-background">
        <video autoplay muted loop playsinline>
            <source src="~/videos/videoplayback.mp4" type="video/mp4" />
        </video>
    </div>

    <div class="auth-container">
        <h2>Đăng nhập</h2>

        <!-- Panda Animation -->
        <div class="panda-container">
            <div class="panda">
                <div class="panda-face">
                    <div class="ear left"></div>
                    <div class="ear right"></div>

                    <div class="eye-patch left">
                        <div class="eye left-eye">
                            <div class="pupil left-pupil"></div>
                        </div>
                    </div>

                    <div class="eye-patch right">
                        <div class="eye right-eye">
                            <div class="pupil right-pupil"></div>
                        </div>
                    </div>

                    <div class="panda-hand left" id="leftHand"></div>
                    <div class="panda-hand right" id="rightHand"></div>

                    <div class="nose"></div>
                    <div class="mouth"></div>
                </div>
            </div>
        </div>

        <form asp-controller="Auth" asp-action="Login" method="post">
            <input type="email" name="email" id="emailInput" placeholder="Email" required />
            <input type="password" name="password" id="passwordInput" placeholder="Mật khẩu" required />
            <button type="submit">Đăng nhập</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <p class="text-danger">@ViewBag.Error</p>
        }
        <p>Bạn chưa có tài khoản? <a asp-controller="Auth" asp-action="Signup">Đăng ký ngay</a></p>
        <p><a asp-controller="Auth" asp-action="ForgotPassword">Quên mật khẩu?</a></p>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const emailInput = document.getElementById('emailInput');
            const passwordInput = document.getElementById('passwordInput');
            const leftEye = document.querySelector('.left-eye');
            const rightEye = document.querySelector('.right-eye');
            const leftPupil = document.querySelector('.left-pupil');
            const rightPupil = document.querySelector('.right-pupil');
            const leftHand = document.getElementById('leftHand');
            const rightHand = document.getElementById('rightHand');

            // Hàm di chuyển mắt theo con trỏ
            function moveEyes(input) {
                input.addEventListener('input', function (e) {
                    // Tính toán vị trí con trỏ
                    const cursorPosition = this.selectionStart;
                    const textWidth = this.value.length;
                    
                    // Giới hạn di chuyển con ngươi
                    const maxMove = 5;
                    let moveX = 0;

                    if (textWidth > 0) {
                        // Di chuyển mắt dựa trên vị trí con trỏ
                        const ratio = (cursorPosition / textWidth) * 2 - 1; // -1 to 1
                        moveX = ratio * maxMove;
                    }

                    leftPupil.style.transform = `translate(calc(-50% + ${moveX}px), -50%)`;
                    rightPupil.style.transform = `translate(calc(-50% + ${moveX}px), -50%)`;
                });

                // Di chuyển mắt theo chuột khi hover
                input.addEventListener('mousemove', function (e) {
                    const inputRect = this.getBoundingClientRect();
                    const inputCenter = inputRect.left + inputRect.width / 2;
                    const mouseX = e.clientX;
                    
                    const maxMove = 5;
                    const moveX = ((mouseX - inputCenter) / inputRect.width) * maxMove * 2;

                    leftPupil.style.transform = `translate(calc(-50% + ${moveX}px), -50%)`;
                    rightPupil.style.transform = `translate(calc(-50% + ${moveX}px), -50%)`;
                });
            }

            // Xử lý khi focus vào email - mở mắt và nhìn theo
            emailInput.addEventListener('focus', function () {
                leftEye.classList.remove('closed');
                rightEye.classList.remove('closed');
                leftHand.classList.remove('cover-eyes');
                rightHand.classList.remove('cover-eyes');
            });

            // Xử lý khi focus vào password - che mắt
            passwordInput.addEventListener('focus', function () {
                leftEye.classList.add('closed');
                rightEye.classList.add('closed');
                leftHand.classList.add('cover-eyes');
                rightHand.classList.add('cover-eyes');
            });

            // Xử lý khi blur khỏi password - mở tay
            passwordInput.addEventListener('blur', function () {
                if (!this.value) {
                    leftEye.classList.remove('closed');
                    rightEye.classList.remove('closed');
                    leftHand.classList.remove('cover-eyes');
                    rightHand.classList.remove('cover-eyes');
                }
            });

            // Áp dụng hiệu ứng mắt theo dõi cho email input
            moveEyes(emailInput);

            // Reset mắt khi không focus
            document.addEventListener('click', function (e) {
                if (!emailInput.contains(e.target) && !passwordInput.contains(e.target)) {
                    leftPupil.style.transform = 'translate(-50%, -50%)';
                    rightPupil.style.transform = 'translate(-50%, -50%)';
                    
                    if (!passwordInput.value) {
                        leftEye.classList.remove('closed');
                        rightEye.classList.remove('closed');
                        leftHand.classList.remove('cover-eyes');
                        rightHand.classList.remove('cover-eyes');
                    }
                }
            });
        });
    </script>
}