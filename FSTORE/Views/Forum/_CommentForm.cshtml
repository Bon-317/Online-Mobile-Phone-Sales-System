@model FSTORE.Forum.CommentFormModel

<form asp-action="AddComment" asp-controller="Forum" method="post" class="mt-2">
    <input type="hidden" name="postId" value="@Model.PostId" />
    <input type="hidden" name="parentId" value="@Model.ParentId" />

    <div class="mb-2">
        <textarea name="content" class="form-control" rows="3" placeholder="Nhập bình luận..."></textarea>
    </div>

    <button type="submit" class="btn btn-sm btn-primary">💬 Gửi</button>
</form>
<style>
    .comment-box {
        background-color: #f9f9f9;
        transition: all 0.3s ease;
    }

        .comment-box:hover {
            background-color: #f0f0ff;
        }

    .comment-thread .comment-box {
        margin-bottom: 1rem;
    }

        .comment-thread .comment-box .comment-box {
            margin-top: 1rem;
        }

</style>