@model FSTORE.Models.Post
@{
    ViewData["Title"] = "Đăng bài mới";
}

<h2>📝 Đăng bài mới</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Tiêu đề</label>
        <input name="Title" class="form-control" value="@Model?.Title" />
    </div>

    <div class="mb-3">
        <label>Nội dung</label>
        <textarea name="Content" rows="6" class="form-control">@Model?.Content</textarea>
    </div>

    <button type="submit" class="btn btn-primary">📤 Đăng bài</button>
    <a href="/Forum" class="btn btn-secondary">⬅ Quay lại diễn đàn</a>
</form>
