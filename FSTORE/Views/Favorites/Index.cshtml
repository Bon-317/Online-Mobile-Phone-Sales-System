@model List<FSTORE.Models.Product>

@{
    ViewData["Title"] = "Yêu thích";
}

<style>
    .product-list {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        padding: 20px;
        max-width: 100%;
        margin-left: 0;
        margin-right: 0;
        justify-content: start; /* căn trái */
    }

    .product-item {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 16px;
        background-color: #fff;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        transition: transform 0.2s ease;
        overflow: hidden;
        min-height: 420px;
    }

        .product-item:hover {
            transform: translateY(-4px);
        }

        .product-item img {
            width: 100%;
            max-width: 300px;
            height: auto;
            object-fit: contain;
            display: block;
            margin: 0 auto;
        }

        .product-item h3 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
            text-align: center;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 100%;
        }

        .product-item .price {
            font-weight: bold;
            color: #d0021b;
            margin-bottom: 8px;
            text-align: center;
            min-height: 24px;
        }

        .product-item .description {
            font-size: 14px;
            color: #555;
            margin-bottom: 12px;
            text-align: center;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
            min-height: 40px;
        }

        .product-item .actions {
            margin-top: auto;
            display: flex;
            justify-content: center;
            align-items: center;
        }

    .btn-detail {
        padding: 6px 12px;
        background-color: #007bff;
        color: white;
        border-radius: 4px;
        text-decoration: none;
        font-size: 14px;
    }

    .btn-remove {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: #dc3545;
        color: white;
        border: none;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        font-size: 14px;
        cursor: pointer;
    }

    .favorite-icon {
        font-size: 18px;
        color: #dc3545;
        margin-left: 6px;
    }

    @@media (max-width: 768px) {
        .product-list

    {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    .product-item {
        padding: 12px;
    }

        .product-item img {
            height: auto;
        }

    }
</style>

<h2 class="mb-4 text-center">❤️ Sản phẩm yêu thích của bạn</h2>

@if (Model.Any())
{
    <div class="product-list">
        @foreach (var product in Model)
        {
            <div class="product-item">
                <button class="btn-remove" onclick="removeFavorite('@product.ProductId')" title="Xóa khỏi yêu thích">×</button>

                <img src="@product.imageUrl" alt="@product.name" />

                <h3>@product.name <span class="favorite-icon">❤️</span></h3>

                <p class="description">@product.description</p>
                <p class="price">@product.price.ToString("N0") ₫</p>

                <div class="actions">
                    <a href="@Url.Action("Detail", "Product", new { id = product.ProductId })" class="btn-detail">Xem chi tiết</a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">
        Bạn chưa có sản phẩm yêu thích nào. Hãy quay lại
        <a href="@Url.Action("Index", "Product")">trang sản phẩm</a> để thêm nhé!
    </div>
}

@section Scripts {
    <script>
        function removeFavorite(productId) {
            $.ajax({
                url: '/Favorites/Toggle',
                type: 'POST',
                data: { productId: productId },
                success: function (response) {
                    if (!response.isFavorite) {
                        location.reload();
                    }
                },
                error: function () {
                    alert("Không thể xóa khỏi yêu thích. Vui lòng thử lại.");
                }
            });
        }
    </script>
}
