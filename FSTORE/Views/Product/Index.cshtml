@model List<FSTORE.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = Model.Select(p => p.category).Distinct().ToList();
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #ffffff;
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
    }

    /* ========== SIDEBAR ========== */
    .sidebar {
        width: 280px;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        position: fixed;
        left: 0;
        top: 70px;
        bottom: 0;
        overflow-y: auto;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 100;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.3);
    }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        /* Sidebar Scrollbar */
        .sidebar::-webkit-scrollbar {
            width: 8px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 4px;
        }

            .sidebar::-webkit-scrollbar-thumb:hover {
                background: rgba(0, 0, 0, 0.7);
            }

    /* Toggle Button */
    .sidebar-toggle {
        position: fixed;
        left: 280px;
        top: 90px;
        width: 40px;
        height: 40px;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-left: none;
        border-radius: 0 8px 8px 0;
        color: rgba(255, 255, 255, 0.9);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 101;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
    }

        .sidebar-toggle:hover {
            background: rgba(0, 0, 0, 0.95);
            color: #ffffff;
            width: 45px;
        }

    .sidebar.hidden ~ .sidebar-toggle {
        left: 0;
    }

    /* Sidebar Header */
    .sidebar-header {
        padding: 25px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.3);
    }

        .sidebar-header h2 {
            color: rgba(255, 255, 255, 0.95);
            font-size: 1.3rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }

    /* Category List */
    .category-list {
        padding: 10px 0;
    }

    .category-item {
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .category-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 15px 20px;
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
        position: relative;
        cursor: pointer;
        background: transparent;
        border: none;
        width: 100%;
        text-align: left;
    }

        .category-link::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: #000000;
            transform: scaleY(0);
            transition: transform 0.3s ease;
        }

        .category-link:hover {
            background: rgba(0, 0, 0, 0.5);
            color: #ffffff;
            padding-left: 25px;
        }

            .category-link:hover::before {
                transform: scaleY(1);
            }

        .category-link.active {
            background: rgba(0, 0, 0, 0.6);
            color: #ffffff;
            padding-left: 25px;
        }

            .category-link.active::before {
                transform: scaleY(1);
            }

    .category-icon {
        margin-right: 12px;
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.7);
        transition: color 0.3s ease;
    }

    .category-link:hover .category-icon,
    .category-link.active .category-icon {
        color: #ffffff;
    }

    .category-count {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
        background: rgba(255, 255, 255, 0.1);
        padding: 3px 10px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .category-link:hover .category-count,
    .category-link.active .category-count {
        background: rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.8);
    }

    /* Main Content with Sidebar */
    .page-wrapper {
        display: flex;
        min-height: calc(100vh - 70px);
        position: relative;
    }

    .main-content {
        flex: 1;
        margin-left: 280px;
        transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        z-index: 1;
        padding: 60px 20px 80px;
    }

    .sidebar.hidden ~ .main-content {
        margin-left: 0;
    }

    /* Particles */
    .particles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        opacity: 0.3;
    }

    .particle {
        position: absolute;
        background: rgba(200, 200, 200, 0.4);
        border-radius: 50%;
        animation: float linear infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(100vh) rotate(0deg);
            opacity: 0;
        }

        10% {
            opacity: 1;
        }

        90% {
            opacity: 1;
        }

        100% {
            transform: translateY(-100px) rotate(360deg);
            opacity: 0;
        }
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Header Section */
    .page-header {
        text-align: center;
        margin-bottom: 60px;
        animation: fadeInDown 1s ease;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header h1 {
        font-size: 3.5rem;
        font-weight: 700;
        margin-bottom: 15px;
        background: linear-gradient(120deg, #333, #666, #333);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradientText 3s ease infinite;
    }

    @@keyframes gradientText {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    .hero-subtitle {
        font-size: 1.3rem;
        color: #666;
        font-weight: 300;
        letter-spacing: 1px;
        animation: fadeIn 1s ease 0.3s both;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* Category Group */
    .category-group {
        margin-bottom: 60px;
        animation: fadeInUp 0.8s ease both;
        position: relative;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .category-group h5 {
        color: #333;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 30px;
        padding: 20px 30px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 15px;
        border-left: 5px solid #000000;
        display: inline-block;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
    }

    /* Scroll Container */
    .scroll-container {
        position: relative;
        padding: 20px 60px;
    }

    .h-scroll {
        display: flex;
        gap: 25px;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding: 10px 0 20px;
        scrollbar-width: thin;
        scrollbar-color: #333 rgba(0, 0, 0, 0.1);
    }

        .h-scroll::-webkit-scrollbar {
            height: 10px;
        }

        .h-scroll::-webkit-scrollbar-track {
            background: #f0f0f0;
            border-radius: 10px;
        }

        .h-scroll::-webkit-scrollbar-thumb {
            background: linear-gradient(90deg, #333, #000);
            border-radius: 10px;
        }

            .h-scroll::-webkit-scrollbar-thumb:hover {
                background: linear-gradient(90deg, #000, #333);
            }

    /* Scroll Buttons */
    .scroll-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 55px;
        height: 55px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, #333, #000);
        color: #ffffff;
        font-size: 2.5rem;
        font-weight: bold;
        cursor: pointer;
        z-index: 10;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

        .scroll-btn:hover {
            transform: translateY(-50%) scale(1.15);
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.5);
        }

        .scroll-btn.prev {
            left: 0;
        }

        .scroll-btn.next {
            right: 0;
        }

    /* Product Card */
    .product-card {
        min-width: 320px;
        max-width: 320px;
        transition: all 0.4s ease;
        cursor: pointer;
        text-decoration: none;
        display: block;
        color: inherit;
    }

        .product-card .card {
            border: none;
            border-radius: 20px;
            overflow: visible;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
            transition: all 0.4s ease;
            height: 100%;
            position: relative;
        }

        .product-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: 20px;
            padding: 2px;
            background: linear-gradient(135deg, #333, #000, #333);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .product-card:hover::before {
            opacity: 1;
        }

        .product-card:hover {
            transform: translateY(-15px);
        }

            .product-card:hover .card {
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            }

    .card-img-top {
        height: 154px;
        object-fit: contain;
        transition: transform 0.5s ease;
        border-radius: 15px;
        margin: 15px auto 0 auto;
        width: calc(100% - 30px);
        max-width: 250px;
        display: block;
        background: #FFFFFF;
        padding: 10px;
    }

    .product-card:hover .card-img-top {
        transform: scale(1.15);
    }

    .card-body {
        padding: 20px 25px 25px 25px;
    }

    .product-category {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
        background: linear-gradient(135deg, #333, #000);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 10px;
    }

    .card-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 12px;
        min-height: 56px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-text {
        font-size: 0.95rem;
        color: #666;
        line-height: 1.6;
        margin-bottom: 15px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        min-height: 48px;
    }

    .product-price {
        font-size: 1.6rem;
        font-weight: 700;
        background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 10px;
    }

    .product-stock {
        font-size: 0.95rem;
        color: #28a745;
        font-weight: 600;
        margin-bottom: 0;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .product-stock::before {
            content: '●';
            color: #28a745;
            font-size: 1.2rem;
        }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        border: 2px solid rgba(0, 0, 0, 0.2);
        color: #666;
        font-size: 1.3rem;
        animation: fadeIn 1s ease;
        box-shadow: 0 5px 30px rgba(0, 0, 0, 0.1);
    }

    /* Decorative Circles */
    .deco-circle {
        position: fixed;
        border: 2px solid rgba(0, 0, 0, 0.1);
        border-radius: 50%;
        animation: rotate 20s linear infinite;
        pointer-events: none;
    }

    .deco-circle-1 {
        width: 500px;
        height: 500px;
        top: -250px;
        right: -250px;
    }

    .deco-circle-2 {
        width: 400px;
        height: 400px;
        bottom: -200px;
        left: -200px;
        animation-direction: reverse;
        animation-duration: 25s;
    }

    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .sidebar {
            transform: translateX(-100%);
        }

            .sidebar.show {
                transform: translateX(0);
            }

        .main-content {
            margin-left: 0 !important;
        }

        .sidebar-toggle {
            left: 0 !important;
        }

        .sidebar.show ~ .sidebar-toggle {
            left: 280px !important;
        }
    }

    @@media (max-width: 768px) {
        .page-header h1 {
            font-size: 2.5rem;
        }

        .hero-subtitle {
            font-size: 1rem;
        }

        .category-group h5 {
            font-size: 1.5rem;
            padding: 15px 20px;
        }

        .product-card {
            min-width: 280px;
            max-width: 280px;
        }

        .scroll-btn {
            width: 45px;
            height: 45px;
            font-size: 2rem;
        }

        .scroll-container {
            padding: 20px 50px;
        }

        .sidebar {
            width: 260px;
        }

            .sidebar.show ~ .sidebar-toggle {
                left: 260px !important;
            }
    }
</style>

<!-- Page Wrapper -->
<div class="page-wrapper">
    <!-- Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h2><i class="fas fa-list"></i> Danh mục</h2>
        </div>
        <div class="category-list">
            <div class="category-item">
                <button class="category-link active" data-filter="all">
                    <span>
                        <i class="fas fa-border-all category-icon"></i>
                        Tất cả sản phẩm
                    </span>
                    <span class="category-count">@Model.Count()</span>
                </button>
            </div>
            @foreach (var cat in categories)
            {
                var count = Model.Count(p => p.category == cat);
                <div class="category-item">
                    <button class="category-link" data-filter="@cat">
                        <span>
                            <i class="fas fa-tag category-icon"></i>
                            @cat
                        </span>
                        <span class="category-count">@count</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Sidebar Toggle Button -->
    <button class="sidebar-toggle" id="sidebarToggle">
        <i class="fas fa-chevron-left"></i>
    </button>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <!-- Particles -->
        <div class="particles" id="particles"></div>

        <!-- Decorative Circles -->
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>

        <div class="container">
            <!-- Header -->
            <div class="page-header">
                <h1>Sản phẩm FSTORE</h1>
                <p class="hero-subtitle">Khám phá bộ sưu tập sản phẩm tuyệt vời của chúng tôi</p>
            </div>

            <!-- Product Groups -->
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <p>Không có sản phẩm nào để hiển thị.</p>
                </div>
            }
            else
            {
                <div class="product-groups">
                    @foreach (var cat in categories)
                    {
                        <div class="category-group" data-group="@cat">
                            <h5>@cat</h5>
                            <div class="scroll-container">
                                <button class="scroll-btn prev" data-target="@cat">‹</button>
                                <div class="h-scroll" data-scroll="@cat">
                                    @foreach (var product in Model.Where(p => p.category == cat))
                                    {
                                        <a href="@Url.Action("Detail", "Product", new { id = product.ProductId })"
                                           class="product-card item-card"
                                           data-category="@product.category">
                                            <div class="card">
                                                <img src="@product.imageUrl"
                                                     alt="@product.name"
                                                     class="card-img-top"
                                                     onerror="this.onerror=null;this.src='@Url.Content("~/images/default.png")'" />
                                                <div class="card-body">
                                                    <div class="product-category">@product.category</div>
                                                    <h5 class="card-title">@product.name</h5>
                                                    <p class="card-text">@product.description</p>
                                                    <div class="product-price">@product.price.ToString("N0") VND</div>
                                                    <p class="product-stock">Kho còn: @product.stock</p>
                                                </div>
                                            </div>
                                        </a>
                                    }
                                </div>
                                <button class="scroll-btn next" data-target="@cat">›</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Create floating particles
    const particlesContainer = document.getElementById('particles');
    const particleCount = 30;

    for (let i = 0; i < particleCount; i++) {
        const particle = document.createElement('div');
        particle.className = 'particle';

        const size = Math.random() * 5 + 2;
        particle.style.width = size + 'px';
        particle.style.height = size + 'px';
        particle.style.left = Math.random() * 100 + '%';
        particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
        particle.style.animationDelay = Math.random() * 5 + 's';

        particlesContainer.appendChild(particle);
    }

    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const toggleIcon = sidebarToggle.querySelector('i');

    sidebarToggle.addEventListener('click', () => {
        if (window.innerWidth <= 1024) {
            sidebar.classList.toggle('show');
        } else {
            sidebar.classList.toggle('hidden');
        }

        // Update icon
        if (sidebar.classList.contains('hidden') || !sidebar.classList.contains('show')) {
            toggleIcon.className = 'fas fa-chevron-right';
        } else {
            toggleIcon.className = 'fas fa-chevron-left';
        }
    });

    // Category filter from sidebar
    const categoryLinks = document.querySelectorAll('.category-link');
    const categoryGroups = document.querySelectorAll('[data-group]');

    categoryLinks.forEach(link => {
        link.addEventListener('click', () => {
            const selected = link.getAttribute('data-filter');

            // Update active state
            categoryLinks.forEach(l => l.classList.remove('active'));
            link.classList.add('active');

            // Filter groups
            categoryGroups.forEach(group => {
                const groupCat = group.getAttribute('data-group');
                group.style.display = (selected === 'all' || groupCat === selected) ? 'block' : 'none';
            });

            // Close sidebar on mobile after selection
            if (window.innerWidth <= 1024) {
                sidebar.classList.remove('show');
                toggleIcon.className = 'fas fa-chevron-right';
            }
        });
    });

    // Horizontal scroll buttons
    document.querySelectorAll('.scroll-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const target = btn.getAttribute('data-target');
            const container = document.querySelector(`[data-scroll="${target}"]`);
            if (!container) return;

            const cardWidth = container.querySelector('.item-card')?.getBoundingClientRect().width || 320;
            const gap = 25;
            const delta = (btn.classList.contains('next') ? 1 : -1) * (cardWidth + gap) * 2;
            container.scrollBy({ left: delta, behavior: 'smooth' });
        });
    });

    // Handle window resize
    window.addEventListener('resize', () => {
        if (window.innerWidth > 1024) {
            sidebar.classList.remove('show');
        }
    });
</script>