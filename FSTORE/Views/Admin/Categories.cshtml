@model List<Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "_AdminLayout";
}

<h2>📦 Quản lý danh mục sản phẩm</h2>

<form asp-action="AddCategory" method="post" class="mb-4">
    <input type="text" name="name" placeholder="Tên danh mục mới" required class="form-control w-50 d-inline" />
    <button type="submit" class="btn btn-success">Thêm danh mục</button>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên danh mục</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>
                    <form asp-action="UpdateCategory" method="post" class="d-flex">
                        <input type="hidden" name="id" value="@cat.Id" />
                        <input type="text" name="name" value="@cat.Name" class="form-control me-2" />
                        <button type="submit" class="btn btn-primary btn-sm">Cập nhật</button>
                    </form>
                </td>
                <td>
                    <a class="btn btn-info btn-sm" href="/Admin/ProductsByCategory?category=@cat.Name">Xem sản phẩm</a>
                </td>
            </tr>
        }
    </tbody>
</table>
