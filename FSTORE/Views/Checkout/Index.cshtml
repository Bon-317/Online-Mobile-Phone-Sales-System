@model FSTORE.Models.OrderModel
@{
    ViewData["Title"] = "Thanh toán thành công";
}

<!-- Import Tailwind -->
<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gradient-to-br from-green-50 to-blue-50 py-8 px-4">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="bg-white rounded-2xl shadow-lg p-8 mb-6 text-center">
            <h1 class="text-3xl font-bold text-green-600 mb-2">Thanh toán thành công!</h1>
            <p class="text-gray-600">Cảm ơn bạn đã mua sắm tại FSTORE</p>
        </div>

        @if (Model != null)
        {
            <!-- Thông tin đơn hàng -->
            <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
                <h2 class="text-xl font-bold text-gray-800 mb-4">Thông tin đơn hàng</h2>
                <div class="space-y-2 text-gray-700">
                    <p><span class="font-semibold">Mã đơn hàng:</span> @Model.OrderId</p>
                    <p><span class="font-semibold">Họ tên:</span> @Model.UserName</p>
                    <p><span class="font-semibold">Email:</span> @Model.Email</p>
                    <p><span class="font-semibold">Số điện thoại:</span> @Model.Phone</p>
                    <p><span class="font-semibold">Địa chỉ:</span> @Model.Address</p>
                    <p>
                        <span class="font-semibold">Trạng thái thanh toán:</span>
                        <span class="text-green-600 font-bold">@Model.PaymentStatus</span>
                    </p>
                </div>
            </div>

            <!-- Danh sách sản phẩm -->
            <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
                <h2 class="text-xl font-bold text-gray-800 mb-4">Chi tiết sản phẩm</h2>
                <div class="space-y-4">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" class="w-20 h-20 rounded-lg object-cover" />
                                }
                                else
                                {
                                    <div class="w-20 h-20 bg-gray-200 rounded-lg flex items-center justify-center">
                                        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16" />
                                        </svg>
                                    </div>
                                }

                                <div class="flex-1">
                                    <h3 class="font-semibold text-gray-800 mb-1">@item.Name</h3>
                                    <p class="text-sm text-gray-600">Số lượng: @item.Quantity</p>
                                </div>
                                <div class="text-right">
                                    <p class="font-bold text-blue-600">@item.Price.ToString("N0") ₫</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-gray-500">Không có sản phẩm nào trong đơn hàng.</p>
                    }
                </div>

                <!-- Tổng tiền -->
                <div class="mt-6 pt-6 border-t border-gray-200">
                    <div class="flex justify-between text-xl font-bold text-gray-900 pt-3">
                        <span>Tổng cộng</span>
                        <span class="text-green-600">@Model.TotalAmount.ToString("N0") ₫</span>
                    </div>
                </div>
            </div>

            <!-- Nút điều hướng -->
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/OrderHistory" class="flex-1 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-xl shadow-md transition">
                    Xem lịch sử đơn hàng
                </a>
                <a href="/" class="flex-1 text-center bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-4 px-6 rounded-xl shadow-md transition">
                    Về trang chủ
                </a>
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-lg p-6 text-center">
                <p class="text-gray-600 mb-4">Không có dữ liệu đơn hàng để hiển thị.</p>
                <a href="/" class="inline-flex items-center gap-2 bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-3 px-6 rounded-xl shadow-md transition">
                    Về trang chủ
                </a>
            </div>
        }
    </div>
</div>
